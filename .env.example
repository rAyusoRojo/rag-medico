OPENAI_API_KEY=
OPENAI_MODEL=GPT-5.4 nano #gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
# Cuántos fragmentos pasan al LLM tras el reranking (los mejores según el cross-encoder).
VECTOR_TOP_K=5
# Cuántos candidatos devuelve Chroma en la búsqueda vectorial (recall amplio) antes del rerank.
# Debe ser >= VECTOR_TOP_K; si es menor, el código usa max(VECTOR_RECALL_K, VECTOR_TOP_K).
VECTOR_RECALL_K=20
# Cross-encoder en español (STS). Multilingüe alternativo: cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
CROSS_ENCODER_MODEL=nflechas/spanish-BERT-sts
# true: recall VECTOR_RECALL_K + cross-encoder. false: solo los VECTOR_TOP_K por similitud vectorial (sin cargar HF).
# Pon false si el rerank empeora respuestas (p. ej. texto médico en español vs modelo entrenado en inglés).
RERANKING_ENABLED=true
CHROMA_COLLECTION=rag_medico_docs
CHROMA_PERSIST_DIRECTORY=.chroma
DOCUMENTS_PATH=data/documents
CHUNK_SIZE=700
CHUNK_OVERLAP=120
